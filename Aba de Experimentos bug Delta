local function loadPlaylist()
    local s, r = pcall(function() return readfile and readfile(FILE_NAME) end)
    if s and r then
        local ds, dr = pcall(function() return HttpService:JSONDecode(r) end)
        if ds and type(dr) == "table" then savedSongs = dr end
    end
end

local function savePlaylist()
    pcall(function() if writefile then writefile(FILE_NAME, HttpService:JSONEncode(savedSongs)) end end)
end
