local function Create(className, parent, properties, corner, stroke)
    local obj = Instance.new(className)
    for k, v in pairs(properties) do obj[k] = v end
    if corner then Instance.new("UICorner", obj).CornerRadius = UDim.new(0, corner) end
    if stroke then
        local str = Instance.new("UIStroke", obj)
        for k, v in pairs(stroke) do str[k] = v end
    end
    if parent then obj.Parent = parent end return obj
end

