-- Função do Sistema de Áudio All puxando diretamente dos IDs salvos na interface
local function tocarEmOutroJogador(targetPlayer)
    if targetPlayer == lp then return end
    if #savedSongs == 0 then return end
    
    local character = targetPlayer.Character
    if not character then return end
    
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local selectedSong = savedSongs[math.random(1, #savedSongs)]
    local audioID = selectedSong.id
    
    local GunSoundEvent = ReplicatedStorage:FindFirstChild("1GuinSound1s", true)
    if GunSoundEvent then
        task.spawn(function()
            pcall(function()
                GunSoundEvent:FireServer(hrp, audioID, 10)
            end)
        end)
    end
    
    local GuinRemote = ReplicatedStorage:FindFirstChild("RE") and ReplicatedStorage.RE:FindFirstChild("1Gu1n")
    if GuinRemote then
        task.spawn(function()
            pcall(function()
                GuinRemote:FireServer(
                    hrp,
                    hrp,
                    Vector3.new(0, -1, 0),
                    Vector3.new(0, 0, 0),
                    hrp,
                    hrp,
                    audioID,
                    audioID,
                    {[1] = true},
                    {
                        [1] = 25,
                        [2] = Vector3.new(0.25, 0.25, 100),
                        [3] = BrickColor.new('Bright yellow'),
                        [4] = 0.25,
                        [5] = Enum.Material.SmoothPlastic,
                        [6] = 0.25
                    },
                    true,
                    false
                )
            end)
        end)
    end
    
    task.spawn(function()
        pcall(function()
            local sound = Instance.new("Sound")
            sound.SoundId = "rbxassetid://" .. audioID
            sound.Volume = 10
            sound.Parent = hrp
            sound:Play()
            
            sound.Ended:Connect(function()
                sound:Destroy()
            end)
            
            task.delay(30, function()
                if sound and sound.Parent then
                    sound:Destroy()
                end
            end)
        end)
    end)
end

-- Botões de Ativar e Desativar Loop na Interface
LoopBtn.MouseButton1Click:Connect(function()
    if #savedSongs == 0 then
        LoopBtn.Text = "       SEM IDS!"
        task.delay(1.5, function()
            LoopBtn.Text = "       ATIVAR LOOP"
        end)
        return
    end
    
    if not isLoopingActive then
        isLoopingActive = true
        LoopBtn.Text = "       LOOP ATIVO"
        
        loopTask = task.spawn(function()
            while isLoopingActive do
                for _, plr in ipairs(Players:GetPlayers()) do
                    if plr ~= lp and plr.Character then
                        tocarEmOutroJogador(plr)
                    end
                end
                task.wait(2)
            end
        end)
    end
end)

StopBtn.MouseButton1Click:Connect(function()
    isLoopingActive = false
    LoopBtn.Text = "       ATIVAR LOOP"
    if loopTask then
        task.cancel(loopTask)
        loopTask = nil
    end
end)
